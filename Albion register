"""
albion_register.py — Registro de membros via Albion Online API (servidor Americas)

Comandos:
  /albion_register <nick>   → Qualquer usuário (Forasteiro) verifica se está na XnoMercy
  /registrar <user> <nick>  → Staff/Recrutador registra outro usuário manualmente
"""

import discord
from discord.ext import commands
from discord import app_commands
import requests
import asyncio
import database as db

# ── Configuração ───────────────────────────────────────────────────────────────
ALBION_API  = 'https://gameinfo.albiononline.com/api/gameinfo'
GUILD_NAME  = 'XnoMercy'   # Nome exato da guild no jogo (case-insensitive na comparação)
ROLE_MEMBRO = 'Membro'
ROLE_FORASTEIRO = 'Forasteiro'

# Cargos que podem usar /registrar
STAFF_ROLES = {'Líder', 'Vice Líder', 'Officer', 'Sub Officer', 'Staff', 'Recrutador'}


# ── Helpers ────────────────────────────────────────────────────────────────────
def _search_player(nick: str) -> dict | None:
    """
    Busca jogador na API do Albion Online (Americas).
    Retorna o dict do jogador ou None se não encontrado.
    """
    try:
        url = f'{ALBION_API}/search?q={requests.utils.quote(nick)}'
        r = requests.get(url, timeout=12, headers={'User-Agent': 'XnoMercy-Bot/2.0'})
        if not r.ok:
            return None
        data = r.json()
        players = data.get('players', [])
        # Busca match exato (case-insensitive)
        return next(
            (p for p in players if p.get('Name', '').lower() == nick.lower()),
            None
        )
    except Exception as e:
        print(f'[albion_register] Erro na API: {e}')
        return None


def _check_guild(player: dict) -> tuple[bool, str]:
    """Verifica se o jogador está na guild XnoMercy. Retorna (bool, guild_name)."""
    guild_name = player.get('GuildName') or ''
    return guild_name.lower() == GUILD_NAME.lower(), guild_name


async def _apply_registration(
    member: discord.Member,
    guild: discord.Guild,
    player_name: str,
    reason: str
) -> tuple[bool, str]:
    """
    Aplica o registro: remove Forasteiro, adiciona Membro, muda nick.
    Retorna (sucesso, mensagem_de_erro).
    """
    try:
        membro_role     = discord.utils.get(guild.roles, name=ROLE_MEMBRO)
        forasteiro_role = discord.utils.get(guild.roles, name=ROLE_FORASTEIRO)

        if membro_role:
            await member.add_roles(membro_role, reason=reason)
        if forasteiro_role and forasteiro_role in member.roles:
            await member.remove_roles(forasteiro_role, reason=reason)

        try:
            await member.edit(nick=player_name, reason=reason)
        except discord.Forbidden:
            pass  # Bot não pode mudar nick do dono do servidor, ok

        return True, ''
    except discord.Forbidden:
        return False, 'Sem permissão para alterar cargos deste usuário.'
    except Exception as e:
        return False, str(e)


async def _send_log(guild: discord.Guild, embed: discord.Embed):
    """Envia log no canal configurado."""
    try:
        log_ch_id = db.get_config('channel_logs')
        if log_ch_id:
            ch = guild.get_channel(int(log_ch_id))
            if ch:
                await ch.send(embed=embed)
    except Exception:
        pass


# ── Cog ───────────────────────────────────────────────────────────────────────
class AlbionRegister(commands.Cog):
    def __init__(self, bot: commands.Bot):
        self.bot = bot

    # ── /albion_register ──────────────────────────────────────────────────────
    @app_commands.command(
        name='albion_register',
        description='Registre seu nick do Albion Online para receber o cargo de Membro'
    )
    @app_commands.describe(nick='Seu nick exato no Albion Online (respeita maiúsculas)')
    async def albion_register(self, interaction: discord.Interaction, nick: str):
        """Disponível para qualquer usuário — verifica guild XnoMercy automaticamente."""
        await interaction.response.defer(ephemeral=True)

        # Já é Membro?
        membro_role = discord.utils.get(interaction.guild.roles, name=ROLE_MEMBRO)
        if membro_role and membro_role in interaction.user.roles:
            await interaction.followup.send(
                'ℹ️ Você já possui o cargo de **Membro**.',
                ephemeral=True
            )
            return

        # Busca jogador (executor para não bloquear o loop)
        loop   = asyncio.get_event_loop()
        player = await loop.run_in_executor(None, _search_player, nick)

        if not player:
            await interaction.followup.send(
                f'❌ Jogador **{nick}** não encontrado no servidor Americas.\n'
                '> Verifique o nick (maiúsculas e minúsculas importam).',
                ephemeral=True
            )
            return

        in_guild, guild_name = _check_guild(player)
        player_name = player.get('Name', nick)

        if not in_guild:
            await interaction.followup.send(
                f'❌ **{player_name}** não está na guild **XnoMercy**.\n'
                f'> Guild atual: **{guild_name or "Nenhuma"}**\n'
                '> Entre na guild no Albion Online e tente novamente.',
                ephemeral=True
            )
            return

        # Aplica
        ok, err = await _apply_registration(
            member=interaction.user,
            guild=interaction.guild,
            player_name=player_name,
            reason=f'Auto-registro Albion: {player_name}'
        )

        if not ok:
            await interaction.followup.send(f'❌ Erro ao aplicar cargo: {err}', ephemeral=True)
            return

        # Log
        embed = discord.Embed(
            title='✅ Membro Registrado',
            color=0x22c55e
        )
        embed.add_field(name='Discord', value=interaction.user.mention, inline=True)
        embed.add_field(name='Nick Albion', value=player_name, inline=True)
        embed.add_field(name='Guild', value=guild_name, inline=True)
        embed.set_footer(text='Registro automático via /albion_register')
        await _send_log(interaction.guild, embed)

        await interaction.followup.send(
            f'✅ **Registro concluído!**\n\n'
            f'> 🎮 Nick: **{player_name}**\n'
            f'> 🏰 Guild: **{guild_name}** ✓\n'
            f'> 🎖️ Cargo **{ROLE_MEMBRO}** atribuído\n'
            f'> ❌ Cargo **{ROLE_FORASTEIRO}** removido\n\n'
            f'Bem-vindo à **XnoMercy**, {player_name}! ⚔️',
            ephemeral=True
        )

    # ── /registrar ────────────────────────────────────────────────────────────
    @app_commands.command(
        name='registrar',
        description='[Staff] Registra manualmente um membro do Discord'
    )
    @app_commands.describe(
        usuario='Membro do Discord a ser registrado',
        nick='Nick exato do jogador no Albion Online'
    )
    async def registrar(
        self,
        interaction: discord.Interaction,
        usuario: discord.Member,
        nick: str
    ):
        """Apenas Staff, Recrutadores, Officers e Líderes podem usar."""
        # Verifica permissão
        user_role_names = {r.name for r in interaction.user.roles}
        if not (user_role_names & STAFF_ROLES):
            await interaction.response.send_message(
                '❌ Sem permissão. Apenas Staff, Recrutadores e Líderes podem usar `/registrar`.',
                ephemeral=True
            )
            return

        await interaction.response.defer(ephemeral=True)

        # Busca jogador
        loop   = asyncio.get_event_loop()
        player = await loop.run_in_executor(None, _search_player, nick)

        if not player:
            await interaction.followup.send(
                f'❌ Jogador **{nick}** não encontrado no servidor Americas.',
                ephemeral=True
            )
            return

        player_name      = player.get('Name', nick)
        in_guild, guild_name = _check_guild(player)

        # Registra mesmo fora da guild (registro manual — staff decide)
        ok, err = await _apply_registration(
            member=usuario,
            guild=interaction.guild,
            player_name=player_name,
            reason=f'Registro manual por {interaction.user.name}: {player_name}'
        )

        if not ok:
            await interaction.followup.send(f'❌ Erro ao aplicar cargo: {err}', ephemeral=True)
            return

        # Log
        guild_status = (
            f'✓ Está na guild **{guild_name}**' if in_guild
            else f'⚠️ **{guild_name or "Sem guild"}** (não é XnoMercy)'
        )
        embed = discord.Embed(
            title='✅ Membro Registrado (Manual)',
            color=0x3b82f6
        )
        embed.add_field(name='Discord', value=usuario.mention, inline=True)
        embed.add_field(name='Nick Albion', value=player_name, inline=True)
        embed.add_field(name='Guild', value=guild_name or 'N/A', inline=True)
        embed.add_field(name='Registrado por', value=interaction.user.mention, inline=False)
        embed.set_footer(text='Registro manual via /registrar')
        await _send_log(interaction.guild, embed)

        await interaction.followup.send(
            f'✅ **{usuario.display_name}** registrado como **{player_name}**!\n'
            f'> {guild_status}\n'
            f'> Cargo **{ROLE_MEMBRO}** atribuído\n'
            f'> Cargo **{ROLE_FORASTEIRO}** removido',
            ephemeral=True
        )


async def setup(bot: commands.Bot):
    await bot.add_cog(AlbionRegister(bot))
